{
  "name": "@polyterminal/data-collector",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "report": "tsx src/adequacyReport.ts",
    "validate-markouts": "tsx src/replay/validateMarkouts.ts",
    "validate-queue-model": "tsx src/replay/validateQueueModel.ts",
    "run-passive-policy": "tsx src/replay/passiveQuoteSimulator.ts",
    "score-adverse-selection": "tsx src/replay/adverseSelectionScorer.ts",
    "run-btc-yes-late-asia-v1": "tsx src/replay/btcYesLateAsiaV1.ts",
    "run-btc-yes-late-asia-v1-capped": "tsx src/replay/btcYesLateAsiaV1Capped.ts",
    "run-btc-maker-v2": "tsx src/replay/btcMakerV2.ts",
    "run-btc-maker-v2-capped": "tsx src/replay/btcMakerV2Capped.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@polyterminal/kalshi-client": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
