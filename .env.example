POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_DATA_BASE=https://data-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/

WORKER_PORT=4000
NEXT_PUBLIC_WORKER_URL=http://localhost:4000

BINANCE_BTC_WS=wss://stream.binance.com:9443/ws/btcusdt@trade

# Required for wallet connect (Reown / WalletConnect Cloud)
# get from https://dashboard.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# -----------------------------------------------------------------------------
# Polymarket has TWO parallel trading flows on Polygon. Choose one:
#
# 1) Safe-proxy flow (sigType=2)  — DEFAULTS BELOW.
#    For polymarket.com browser-wallet users with a Gnosis Safe proxy.
#    Collateral: USDC.e. Exchange: 0x4bFb…982E.
#    The official @polymarket/clob-client SDK targets this path on Polygon mainnet.
#
# 2) Deposit-wallet flow (sigType=3) — new path for pure-API users.
#    Collateral: pUSD (0xC011a7E12a19f7B1f670d46F03B03f3342E82DFB).
#    Exchange: 0xE111180000d2663C0091e4f400237545B87B996B.
#    Override the env vars below to point at the new contracts.
#
# Docs: https://docs.polymarket.com/api-reference/authentication
#       https://docs.polymarket.com/resources/contracts
# -----------------------------------------------------------------------------

NEXT_PUBLIC_POLYMARKET_COLLATERAL=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
NEXT_PUBLIC_POLYMARKET_COLLATERAL_SYMBOL=USDC.e
NEXT_PUBLIC_POLYMARKET_EXCHANGE=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E
NEXT_PUBLIC_POLYMARKET_NEG_RISK_EXCHANGE=0xC5d563A36AE78145C45a50134d48A1215220f80a

# Worker-side BTC market selector thresholds (server env only).
# Raise to filter out sleepy long-shot markets.
POLYTERMINAL_MIN_VOL_24H=25000
POLYTERMINAL_MIN_LIQUIDITY=5000
POLYTERMINAL_YES_MIN=0.10
POLYTERMINAL_YES_MAX=0.90
POLYTERMINAL_WATCHLIST_SIZE=8

# Shadow-collection YES range (separate from main selector).
# Widens BTC up/down sampling for the shadow logger only.
POLYTERMINAL_SHADOW_YES_MIN=0.02
POLYTERMINAL_SHADOW_YES_MAX=0.98
